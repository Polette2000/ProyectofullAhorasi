<?xml version="1.0" encoding="UTF-8"?>

<!--
    Configuracion de Logback para inventory-service.
    Genera logs en consola y en archivos JSON dentro de la carpeta logs.
-->
<configuration>

    <!-- Nombre del microservicio usado dentro del log JSON -->
    <property name="APP_NAME" value="inventory-service"/>

    <!-- Logs visibles en consola/terminal -->
    <appender name="CONSOLE" 
              class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Logs estructurados en formato JSON -->
    <appender name="JSON" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/inventory-service.json</file>

        <!-- Crea un archivo nuevo por dia y conserva 30 dias -->
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>logs/inventory-service-%d{yyyy-MM-dd}.json</fileNamePattern>
            <maxHistory>30</maxHistory>//Cantidad de días de logs a conservar.
        </rollingPolicy>

        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <customFields>{"service":"inventory-service"}</customFields>
        </encoder>
    </appender>

    // ROOT LOGGER
        Logger principal global del sistema.
        Todos los logs pasan por aquí.

    <!-- Nivel global de logs -->
    <root level="INFO">
    
        //Enviar logs al appender consola
        <appender-ref ref="CONSOLE"/>

        //Enviar logs al appender JSON
        <appender-ref ref="JSON"/>
    </root>

</configuration>